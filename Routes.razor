<Router AppAssembly="@typeof(Routes).Assembly" AdditionalAssemblies="new[] { typeof(Astrene.Shared.Routes).Assembly }">
    <Found Context="routeData">
        <RouteView RouteData="@routeData" DefaultLayout="@typeof(Astrene.Shared.EmptyLayout)" />
    </Found>
    <NotFound>
        <LayoutView Layout="@typeof(Astrene.Shared.EmptyLayout)">
            <p>Page not found.</p>
        </LayoutView>
    </NotFound>
</Router>
