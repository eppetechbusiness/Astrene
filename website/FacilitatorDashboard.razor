@page "/facilitator/dashboard"

<div class="dashboard">
    <header class="dashboard-header">
        <img src="images/astrene-logo.png" alt="Astrene" class="dashboard-logo" />
        <div class="dashboard-header-right">
            <span class="dashboard-role">Facilitator</span>
            <a href="/login" class="btn btn-outline">Back to login</a>
        </div>
    </header>

    <main class="dashboard-main">
        <h1>Facilitator Dashboard</h1>
        <p class="dashboard-welcome">Welcome, Facilitator User</p>

        <div class="dashboard-grid">
            <div class="dashboard-card">
                <h3>My Courses</h3>
                <p>Create and manage your learning content.</p>
            </div>
            <div class="dashboard-card">
                <h3>Students</h3>
                <p>Track student progress and engagement.</p>
            </div>
            <div class="dashboard-card">
                <h3>Assignments</h3>
                <p>Review submissions and provide feedback.</p>
            </div>
        </div>
    </main>
</div>
