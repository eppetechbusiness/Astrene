@page "/student/dashboard"

<div class="dashboard">
    <header class="dashboard-header">
        <img src="images/astrene-logo.png" alt="Astrene" class="dashboard-logo" />
        <div class="dashboard-header-right">
            <span class="dashboard-role">Student</span>
            <a href="/login" class="btn btn-outline">Back to login</a>
        </div>
    </header>

    <main class="dashboard-main">
        <h1>Student Dashboard</h1>
        <p class="dashboard-welcome">Welcome, Student User</p>

        <div class="dashboard-grid">
            <div class="dashboard-card">
                <h3>My Learning</h3>
                <p>Continue your enrolled courses.</p>
            </div>
            <div class="dashboard-card">
                <h3>Assignments</h3>
                <p>View pending tasks and deadlines.</p>
            </div>
            <div class="dashboard-card">
                <h3>Progress</h3>
                <p>Track your learning achievements.</p>
            </div>
        </div>
    </main>
</div>
