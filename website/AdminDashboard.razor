@page "/admin/dashboard"
@inject UserSession Session
@inject NavigationManager Navigation

<div class="dashboard">
    <header class="dashboard-header">
        <img src="images/astrene-logo.png" alt="Astrene" class="dashboard-logo" />
        <div class="dashboard-header-right">
            <span class="dashboard-role">Administrator</span>
            <button type="button" class="btn btn-outline" @onclick="Logout">Sign out</button>
        </div>
    </header>

    <main class="dashboard-main">
        <h1>Admin Dashboard</h1>
        <p class="dashboard-welcome">Welcome, @Session.Email</p>

        <div class="dashboard-grid">
            <div class="dashboard-card">
                <h3>Users</h3>
                <p>Manage administrators, facilitators, and students.</p>
            </div>
            <div class="dashboard-card">
                <h3>Organisations</h3>
                <p>View and configure organisation settings.</p>
            </div>
            <div class="dashboard-card">
                <h3>Reports</h3>
                <p>Access platform analytics and audit logs.</p>
            </div>
        </div>
    </main>
</div>

@code {
    protected override void OnInitialized()
    {
        if (!Session.IsAuthenticated || Session.Role != "Administrator")
            Navigation.NavigateTo("/login");
    }

    private void Logout()
    {
        Session.SignOut();
        Navigation.NavigateTo("/login");
    }
}
