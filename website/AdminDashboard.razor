@page "/admin/dashboard"
@inject NavigationManager Navigation

<div class="admin-layout">
    <aside class="admin-sidebar">
        <div class="admin-sidebar-brand">
            <img src="images/astrene-logo.png" alt="Astrene" class="admin-brand-logo" />
        </div>

        <nav class="admin-sidebar-nav" aria-label="Admin navigation">
            <button type="button" class="admin-nav-item @(activeNav == "overview" ? "active" : "")" @onclick='() => SetNav("overview")'>Overview</button>

            <p class="admin-nav-section" aria-hidden="true">Management</p>
            <button type="button" class="admin-nav-item @(activeNav == "users" ? "active" : "")" @onclick='() => SetNav("users")'>User Management</button>
            <button type="button" class="admin-nav-item @(activeNav == "courses" ? "active" : "")" @onclick='() => SetNav("courses")'>Course Management</button>
            <button type="button" class="admin-nav-item @(activeNav == "payments" ? "active" : "")" @onclick='() => SetNav("payments")'>Payments</button>
            <button type="button" class="admin-nav-item @(activeNav == "reports" ? "active" : "")" @onclick='() => SetNav("reports")'>Reports</button>
            <button type="button" class="admin-nav-item @(activeNav == "certificates" ? "active" : "")" @onclick='() => SetNav("certificates")'>Certificates</button>

            <p class="admin-nav-section" aria-hidden="true">System</p>
            <button type="button" class="admin-nav-item @(activeNav == "settings" ? "active" : "")" @onclick='() => SetNav("settings")'>Settings</button>
        </nav>

        <a class="admin-sign-out" href="/login">Sign Out</a>
    </aside>

    <div class="admin-body">
        <header class="admin-topbar">
            <div class="admin-topbar-search">
                <svg class="admin-search-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="11" cy="11" r="8" />
                    <path d="m21 21-4.3-4.3" />
                </svg>
                <input type="search" class="admin-search-input" placeholder="Search courses, users, reports..." @bind="headerSearch" @bind:event="oninput" />
            </div>

            <div class="admin-topbar-actions">
                <button type="button" class="admin-icon-btn" aria-label="Notifications">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9" />
                        <path d="M10.3 21a1.94 1.94 0 0 0 3.4 0" />
                    </svg>
                </button>
                <button type="button" class="admin-icon-btn" aria-label="Help">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="12" cy="12" r="10" />
                        <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3" />
                        <path d="M12 17h.01" />
                    </svg>
                </button>
                <button type="button" class="admin-profile" aria-label="Account menu">
                    <span class="admin-avatar">AU</span>
                    <span class="admin-profile-text">
                        <span class="admin-profile-name">Admin User</span>
                        <span class="admin-profile-role">Administrator</span>
                    </span>
                    <svg class="admin-profile-chevron" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="m6 9 6 6 6-6" />
                    </svg>
                </button>
            </div>
        </header>

        <main class="admin-content">
            @if (!string.IsNullOrEmpty(toastMessage))
            {
                <div class="toast">@toastMessage</div>
            }

            @if (activeNav == "overview")
            {
                <section class="hero-banner">
                    <div class="hero-banner-text">
                        <h1>Platform Overview</h1>
                        <p>All systems operational. Last sync 2 minutes ago.</p>
                    </div>
                    <div class="hero-banner-actions">
                        <button type="button" class="btn-hero-outline" @onclick="OpenAddUser">+ Add User</button>
                        <button type="button" class="btn-hero-solid" @onclick='() => SetNav("reports")'>View Reports</button>
                    </div>
                </section>

                <div class="metric-grid">
                    @foreach (var metric in metrics)
                    {
                        <div class="metric-card">
                            <span class="metric-label">@metric.Label</span>
                            <span class="metric-value">@metric.Value</span>
                            <span class="metric-change @metric.ChangeClass">@metric.Change</span>
                            <div class="metric-bar"><span style="width: @(metric.Progress)%"></span></div>
                        </div>
                    }
                </div>

                <div class="dashboard-grid">
                    <div class="dashboard-main-col">
                        <section class="panel">
                            <div class="panel-head">
                                <div>
                                    <h2>Recent Registrations</h2>
                                    <p class="panel-subtitle">New users — last 7 days</p>
                                </div>
                                <button type="button" class="btn-panel-link" @onclick='() => SetNav("users")'>View all</button>
                            </div>
                            <table class="data-table">
                                <thead>
                                    <tr><th>Name</th><th>Role</th><th>Organisation</th><th>Status</th><th>Joined</th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var reg in recentRegistrations)
                                    {
                                        <tr>
                                            <td class="cell-bold">@reg.Name</td>
                                            <td><span class="role-pill @GetRoleClass(reg.Role)">@reg.Role</span></td>
                                            <td>@reg.Organisation</td>
                                            <td><span class="status-dot @GetStatusDotClass(reg.Status)"></span>@reg.Status</td>
                                            <td>@reg.Joined</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </section>

                        <section class="panel">
                            <div class="panel-head">
                                <div class="panel-head-inline">
                                    <h2>Course Approvals Queue</h2>
                                    <span class="pending-badge">38 pending</span>
                                </div>
                            </div>
                            <table class="data-table">
                                <thead>
                                    <tr><th>Course</th><th>Facilitator</th><th>Category</th><th>Action</th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var course in courseApprovals)
                                    {
                                        <tr>
                                            <td class="cell-bold">@course.Course</td>
                                            <td>@course.Facilitator</td>
                                            <td><span class="category-pill">@course.Category</span></td>
                                            <td class="approval-actions">
                                                <button type="button" class="btn-approve" @onclick="() => ApproveCourse(course)">Approve</button>
                                                <button type="button" class="btn-reject" @onclick="() => RejectCourse(course)">Reject</button>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </section>
                    </div>

                    <div class="dashboard-side-col">
                        <section class="panel">
                            <h2>System Alerts</h2>
                            <div class="alert-list">
                                @foreach (var alert in systemAlerts)
                                {
                                    <div class="alert-item @alert.Class">@alert.Message</div>
                                }
                            </div>
                        </section>

                        <section class="panel">
                            <h2>Quick Actions</h2>
                            <div class="quick-actions">
                                @foreach (var action in quickActions)
                                {
                                    <button type="button" class="quick-action-btn" @onclick="() => HandleQuickAction(action)">
                                        <span>@action</span>
                                        <span aria-hidden="true">›</span>
                                    </button>
                                }
                            </div>
                        </section>

                        <section class="panel">
                            <h2>Compliance Status</h2>
                            <div class="compliance-grid">
                                @foreach (var item in complianceStats)
                                {
                                    <div class="compliance-item">
                                        <span class="compliance-value @item.Class">@item.Value</span>
                                        <span class="compliance-label">@item.Label</span>
                                    </div>
                                }
                            </div>
                        </section>
                    </div>
                </div>
            }
            else if (activeNav == "users")
            {
                <section class="panel">
                    <div class="panel-head">
                        <h2>User Management</h2>
                        <button type="button" class="btn-primary-sm" @onclick="OpenAddUser">Add User</button>
                    </div>
                    <div class="panel-toolbar">
                        <input type="text" placeholder="Search users..." @bind="userSearch" @bind:event="oninput" />
                        <select @bind="userRoleFilter">
                            <option value="">All roles</option>
                            <option>Administrator</option>
                            <option>Facilitator</option>
                            <option>Student</option>
                        </select>
                    </div>
                    <table class="data-table">
                        <thead>
                            <tr><th>Name</th><th>Email</th><th>Role</th><th>Organisation</th><th>Status</th><th>Actions</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var user in FilteredUsers)
                            {
                                <tr>
                                    <td class="cell-bold">@user.Name</td>
                                    <td>@user.Email</td>
                                    <td><span class="role-pill @GetRoleClass(user.Role)">@user.Role</span></td>
                                    <td>@user.Organisation</td>
                                    <td><span class="status-dot @GetStatusDotClass(user.Status)"></span>@user.Status</td>
                                    <td class="actions">
                                        <button type="button" class="btn-link" @onclick="() => ToggleUserStatus(user)">@(user.Status == "Active" ? "Deactivate" : "Activate")</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </section>
            }
            else
            {
                <section class="panel placeholder-panel">
                    <h2>@GetNavTitle(activeNav)</h2>
                    <p>This section is ready for UI development. Connect backend APIs when integration begins.</p>
                    <button type="button" class="btn-outline" @onclick='() => SetNav("overview")'>Back to Overview</button>
                </section>
            }
        </main>
    </div>
</div>

@if (showUserModal)
{
    <div class="modal-backdrop" @onclick="CloseModals">
        <div class="modal" @onclick:stopPropagation="true">
            <h3>Add User</h3>
            <div class="form-group"><label>Full Name</label><input @bind="newUserName" /></div>
            <div class="form-group"><label>Email</label><input type="email" @bind="newUserEmail" /></div>
            <div class="form-group">
                <label>Role</label>
                <select @bind="newUserRole">
                    <option>Administrator</option>
                    <option>Facilitator</option>
                    <option>Student</option>
                </select>
            </div>
            <div class="form-group"><label>Organisation</label><input @bind="newUserOrg" /></div>
            <div class="modal-actions">
                <button type="button" class="btn-outline" @onclick="CloseModals">Cancel</button>
                <button type="button" class="btn-primary-sm" @onclick="SaveUser">Save</button>
            </div>
        </div>
    </div>
}

@code {
    private string headerSearch = "";
    private string activeNav = "overview";
    private string userSearch = "";
    private string userRoleFilter = "";
    private string toastMessage = "";
    private bool showUserModal;
    private string newUserName = "";
    private string newUserEmail = "";
    private string newUserRole = "Student";
    private string newUserOrg = "";

    private List<MetricCard> metrics = new()
    {
        new("Total Users", "42,817", "+2,140 this month", "metric-change-up", 78),
        new("Active Courses", "1,824", "38 pending approval", "metric-change-info", 65),
        new("Monthly Revenue", "R284K", "+81% vs last month", "metric-change-up", 81),
        new("Completion Rate", "87%", "Platform average", "metric-change-muted", 87),
    };

    private List<RegistrationRow> recentRegistrations = new()
    {
        new("Thabo Mokoena", "Facilitator", "University of Cape Town", "Active", "Today"),
        new("Nomsa Dlamini", "Student", "University of the Witwatersrand", "Pending", "Yesterday"),
        new("James van der Berg", "Facilitator", "Stellenbosch University", "Active", "2 days ago"),
        new("Priya Naidoo", "Student", "University of Pretoria", "Active", "3 days ago"),
        new("David Okonkwo", "Enterprise", "Rhodes University", "Active", "4 days ago"),
    };

    private List<CourseApprovalRow> courseApprovals = new()
    {
        new("Intro to Data Science", "Dr. Sarah Nkosi", "Technology"),
        new("Financial Literacy 101", "Prof. James Molefe", "Business"),
        new("Digital Marketing Basics", "Lisa van Wyk", "Marketing"),
        new("Workplace Safety", "Mike Botha", "Compliance"),
    };

    private List<SystemAlert> systemAlerts = new()
    {
        new("38 courses awaiting approval", "alert-amber"),
        new("Maintenance: Sun 02:00 SAST", "alert-blue"),
        new("All payment gateways operational", "alert-green"),
    };

    private List<string> quickActions = new()
    {
        "Review Course Approvals",
        "Payment Dashboard",
        "Generate Report",
        "Certificates",
    };

    private List<ComplianceStat> complianceStats = new()
    {
        new("100%", "POPIA", "compliance-green"),
        new("98.4%", "Uptime", "compliance-navy"),
        new("0", "Disputes", "compliance-navy"),
        new("340", "Providers", "compliance-navy"),
    };

    private List<UserRow> users = new()
    {
        new("Sarah Admin", "sarah@astrene.com", "Administrator", "Astrene HQ", "Active"),
        new("John Facilitator", "john@school.edu", "Facilitator", "Greenfield Academy", "Active"),
        new("Emma Student", "emma@school.edu", "Student", "Greenfield Academy", "Active"),
        new("Mike Facilitator", "mike@tech.org", "Facilitator", "Tech Institute", "Inactive"),
        new("Lisa Student", "lisa@school.edu", "Student", "Greenfield Academy", "Locked"),
        new("Tom Student", "tom@tech.org", "Student", "Tech Institute", "Active"),
    };

    private IEnumerable<UserRow> FilteredUsers => users.Where(u =>
        (string.IsNullOrEmpty(userSearch) || u.Name.Contains(userSearch, StringComparison.OrdinalIgnoreCase) || u.Email.Contains(userSearch, StringComparison.OrdinalIgnoreCase)) &&
        (string.IsNullOrEmpty(userRoleFilter) || u.Role == userRoleFilter));

    private static string GetRoleClass(string role) => role switch
    {
        "Facilitator" => "role-facilitator",
        "Student" => "role-student",
        "Enterprise" => "role-enterprise",
        _ => "role-admin"
    };

    private static string GetStatusDotClass(string status) => status switch
    {
        "Active" => "status-active",
        "Pending" => "status-pending",
        _ => "status-inactive"
    };

    private static string GetNavTitle(string nav) => nav switch
    {
        "courses" => "Course Management",
        "payments" => "Payments",
        "reports" => "Reports",
        "certificates" => "Certificates",
        "settings" => "Settings",
        _ => "Section"
    };

    private void ToggleUserStatus(UserRow user) =>
        user.Status = user.Status == "Active" ? "Inactive" : "Active";

    private void OpenAddUser() => showUserModal = true;
    private void CloseModals() => showUserModal = false;

    private void SaveUser()
    {
        if (string.IsNullOrWhiteSpace(newUserName) || string.IsNullOrWhiteSpace(newUserEmail)) return;
        users.Add(new UserRow(newUserName, newUserEmail, newUserRole, newUserOrg, "Active"));
        recentRegistrations.Insert(0, new RegistrationRow(newUserName, newUserRole, newUserOrg, "Active", "Today"));
        newUserName = newUserEmail = newUserOrg = "";
        newUserRole = "Student";
        CloseModals();
        toastMessage = "User added.";
    }

    private void SetNav(string nav) => activeNav = nav;

    private void HandleQuickAction(string action)
    {
        activeNav = action switch
        {
            "Review Course Approvals" => "courses",
            "Payment Dashboard" => "payments",
            "Generate Report" => "reports",
            "Certificates" => "certificates",
            _ => activeNav
        };
        toastMessage = $"{action} opened.";
    }

    private void ApproveCourse(CourseApprovalRow course)
    {
        courseApprovals.Remove(course);
        toastMessage = $"\"{course.Course}\" approved.";
    }

    private void RejectCourse(CourseApprovalRow course)
    {
        courseApprovals.Remove(course);
        toastMessage = $"\"{course.Course}\" rejected.";
    }

    private record MetricCard(string Label, string Value, string Change, string ChangeClass, int Progress);
    private record RegistrationRow(string Name, string Role, string Organisation, string Status, string Joined);
    private record CourseApprovalRow(string Course, string Facilitator, string Category);
    private record SystemAlert(string Message, string Class);
    private record ComplianceStat(string Value, string Label, string Class);

    private class UserRow
    {
        public string Name { get; set; }
        public string Email { get; set; }
        public string Role { get; set; }
        public string Organisation { get; set; }
        public string Status { get; set; }
        public UserRow(string name, string email, string role, string org, string status)
        {
            Name = name; Email = email; Role = role; Organisation = org; Status = status;
        }
    }
}
