@page "/forgot-password"
@using System.Text.RegularExpressions

<div class="login-page">
    <div class="login-card forgot-card">
        @if (!string.IsNullOrEmpty(resetMessage))
        {
            <div class="alert alert-success">@resetMessage</div>
        }

        <fieldset class="forgot-panel">
            <legend>Reset your password</legend>
            <div class="form-group">
                <label for="resetEmail">Email address</label>
                <input id="resetEmail" type="email" placeholder="name@company.com" @bind="forgotPasswordEmail" @bind:event="oninput" />
                @if (!string.IsNullOrEmpty(resetEmailError)) { <span class="field-error">@resetEmailError</span> }
            </div>
            <button type="button" class="btn btn-secondary" @onclick="SendResetLink">Send reset link</button>
        </fieldset>

        <a href="/login" class="link-btn back-link">Back to sign in</a>
    </div>
</div>

@code {
    private static readonly Regex EmailRegex = new(@"^[^@\s]+@[^@\s]+\.[^@\s]+$", RegexOptions.Compiled);

    private string forgotPasswordEmail = string.Empty;
    private string resetEmailError = string.Empty;
    private string resetMessage = string.Empty;

    private void SendResetLink()
    {
        resetEmailError = resetMessage = string.Empty;

        if (string.IsNullOrWhiteSpace(forgotPasswordEmail) || !EmailRegex.IsMatch(forgotPasswordEmail))
        {
            resetEmailError = "Invalid email format.";
            return;
        }

        resetMessage = $"Password reset link sent to {forgotPasswordEmail}.";
    }
}
